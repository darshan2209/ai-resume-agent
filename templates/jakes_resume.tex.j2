<#
  jakes_resume.tex.j2
  Jake's Resume (MIT licensed, by Jake Gutierrez) adapted for ATS safety:
    - NO FontAwesome / marvosym icons (icons become mojibake in ATS text extraction)
    - plain-text contact line: phone | email | linkedin | location (+ optional tagline)
    - fixed section order: Summary, Skills, Experience, Projects, Education,
      Certifications, Additional
    - machine-readability preserved: \pdfgentounicode=1, glyphtounicode, hidelinks
  Rendered by scripts/render_tex.py with custom Jinja2 delimiters
  (<< >> variables, <% %> blocks, <# #> comments). All values arrive pre-escaped.
#>
%-------------------------
% Resume in LaTeX
% Based on: Jake's Resume by Jake Gutierrez (MIT License)
% https://github.com/jakegut/resume
% Adapted: no icons, plain-text contact line, ATS-safe sections
%------------------------

\documentclass[letterpaper,11pt]{article}

\usepackage{latexsym}
\usepackage[empty]{fullpage}
\usepackage{titlesec}
\usepackage[usenames,dvipsnames]{color}
\usepackage{verbatim}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{fancyhdr}
\usepackage[<< babel_lang >>]{babel}
\usepackage{tabularx}
\input{glyphtounicode}

\pagestyle{fancy}
\fancyhf{} % clear all header and footer fields
\fancyfoot{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% Adjust margins
\addtolength{\oddsidemargin}{-0.5in}
\addtolength{\evensidemargin}{-0.5in}
\addtolength{\textwidth}{1in}
\addtolength{\topmargin}{-.5in}
\addtolength{\textheight}{1.0in}

\urlstyle{same}

\raggedbottom
\raggedright
\setlength{\tabcolsep}{0in}

% Sections formatting
\titleformat{\section}{
  \vspace{-4pt}\scshape\raggedright\large
}{}{0em}{}[\color{black}\titlerule \vspace{-5pt}]

% Ensure that generated pdf is machine readable/ATS parsable
\pdfgentounicode=1

%-------------------------
% Custom commands
\newcommand{\resumeItem}[1]{
  \item\small{
    {#1 \vspace{-2pt}}
  }
}

\newcommand{\resumeSubheading}[4]{
  \vspace{-2pt}\item
    \begin{tabular*}{0.97\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & #2 \\
      \textit{\small#3} & \textit{\small #4} \\
    \end{tabular*}\vspace{-7pt}
}

\newcommand{\resumeProjectHeading}[2]{
    \item
    \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
      \small#1 & #2 \\
    \end{tabular*}\vspace{-7pt}
}

\renewcommand\labelitemii{$\vcenter{\hbox{\tiny$\bullet$}}$}

\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=0.15in, label={}]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}
\newcommand{\resumeItemListStart}{\begin{itemize}}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{-5pt}}

%-------------------------------------------
%%%%%%  RESUME STARTS HERE  %%%%%%%%%%%%%%%%

\begin{document}

%----------HEADING----------
\begin{center}
    \textbf{\Huge \scshape << name >>} \\ \vspace{1pt}
<% if contact_line %>
    \small << contact_line >>
<% endif %>
<% if tagline %>
    \\ \vspace{1pt}
    \small\textit{<< tagline >>}
<% endif %>
\end{center}

<% if summary %>
%-----------SUMMARY-----------
\section{<< labels.summary >>}
\begin{itemize}[leftmargin=0.15in, label={}]
    \small{\item{<< summary >>}}
\end{itemize}

<% endif %>
<% if skills %>
%-----------SKILLS-----------
\section{<< labels.skills >>}
\begin{itemize}[leftmargin=0.15in, label={}]
    \small{\item{
<% for s in skills %>
<# s['items'] (not s.items): dot lookup would hit the dict .items() method #>
      \textbf{<< s.category >>}{: << s['items'] >>}<< " \\\\" if not loop.last else "" >>
<% endfor %>
    }}
\end{itemize}

<% endif %>
<% if experience %>
%-----------EXPERIENCE-----------
\section{<< labels.experience >>}
\resumeSubHeadingListStart
<% for job in experience %>
    \resumeSubheading
      {<< job.title >>}{<< job.dates >>}
      {<< job.company >>}{<< job.location >>}
<% if job.bullets %>
      \resumeItemListStart
<% for b in job.bullets %>
        \resumeItem{<< b >>}
<% endfor %>
      \resumeItemListEnd
<% endif %>
<% endfor %>
\resumeSubHeadingListEnd

<% endif %>
<% if projects %>
%-----------PROJECTS-----------
\section{<< labels.projects >>}
\resumeSubHeadingListStart
<% for p in projects %>
    \resumeProjectHeading
      {\textbf{<< p.name >>}<% if p.tech %> $|$ \emph{<< p.tech >>}<% endif %>}{}
<% if p.bullets %>
      \resumeItemListStart
<% for b in p.bullets %>
        \resumeItem{<< b >>}
<% endfor %>
      \resumeItemListEnd
<% endif %>
<% endfor %>
\resumeSubHeadingListEnd

<% endif %>
<% if education %>
%-----------EDUCATION-----------
\section{<< labels.education >>}
\resumeSubHeadingListStart
<% for e in education %>
    \resumeSubheading
      {<< e.school >>}{<< e.location >>}
      {<< e.degree >>}{<< e.dates >>}
<% if e.notes %>
      \resumeItemListStart
<% for n in e.notes %>
        \resumeItem{<< n >>}
<% endfor %>
      \resumeItemListEnd
<% endif %>
<% endfor %>
\resumeSubHeadingListEnd

<% endif %>
<% if certifications %>
%-----------CERTIFICATIONS-----------
\section{<< labels.certifications >>}
\begin{itemize}[leftmargin=0.15in, label={}]
    \small{\item{
<% for c in certifications %>
      << c >><< " \\\\" if not loop.last else "" >>
<% endfor %>
    }}
\end{itemize}

<% endif %>
<% if additional %>
%-----------ADDITIONAL-----------
\section{<< labels.additional >>}
\begin{itemize}[leftmargin=0.15in, label={}]
    \small{\item{
<% for a in additional %>
      \textbf{<< a.label >>}{: << a.text >>}<< " \\\\" if not loop.last else "" >>
<% endfor %>
    }}
\end{itemize}

<% endif %>
%-------------------------------------------
\end{document}
